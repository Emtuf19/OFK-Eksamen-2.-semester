<Page x:Class="_2_Semester_Eksamen.Views.Træner"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:_2_Semester_Eksamen.Views"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1200"
      Background="Wheat"
      Title="Træner">

    <Grid Margin="10,0,10,10">
        <Grid HorizontalAlignment="Center" VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <!-- Image  -->
            <Button Click="Home_Click">
                <Button.Template>
                    <ControlTemplate>
                        <Image Height="122" Width="101" Source="/Icon/odense-logo.png" VerticalAlignment="Top" 
            HorizontalAlignment="Left" Margin="8,10,0,0"  />
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <!-- Træning -->
            <StackPanel  Margin="10,20" Orientation="Horizontal" Grid.Row="0" Grid.ColumnSpan="2" VerticalAlignment="Center" HorizontalAlignment="Left" >
                <Button BorderThickness="0" Background="Transparent" Margin="90,0,0,0" Width="150"  Content="Træning">

                </Button>

                <!-- Aflys Træning -->
                <Button Width="200"  Content="Aflys Træning">

                </Button>

                <!-- Medlemsoversigt -->
                <Button Width="200"  Content="Medlemsoversigt">

                </Button>

                <!-- Begivenheder -->
                <Button Width="200"  Content="Begivenhed">

                </Button>

                <!-- Opret Begivenhed -->
                <Button Width="200"  Content="Opret Begivenhed">

                </Button>

                <!-- Log ud -->
                <Button Width="100"  Content="Log ud">

                </Button>
            </StackPanel>
            <Label Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.ColumnSpan="2">
                Odense Fægte-Klub
            </Label>


            <ListBox ItemsSource="{Binding Practices}" SelectedItem="{Binding ThisPractice, Mode=TwoWay}" Margin="20,0,0,30" Grid.Row="3" Grid.Column="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding PracticeID}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Trainers}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding StartTime, StringFormat=dd-MM-yyyy HH:mm}" />
                            <TextBlock Text="{Binding EndTime, StringFormat=dd-MM-yyyy HH:mm}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ListBox Margin="20,0,0,30" Grid.Row="3" Grid.Column="1" d:ItemsSource="{d:SampleData ItemCount=5}"/>

            <!-- List over Træning   -->


            <!-- Preview over Kalender -->

        </Grid>
    </Grid>
</Page>
