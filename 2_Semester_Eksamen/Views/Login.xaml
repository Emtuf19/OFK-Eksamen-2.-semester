<Page x:Class="_2_Semester_Eksamen.Views.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:_2_Semester_Eksamen.Views"
      mc:Ignorable="d" 
      d:DesignHeight="850"  d:DesignWidth="1200"
      Title="Odense fægteklub - Login">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Image Height="200" Width="127" Source="/Icon/odense-logo.png" VerticalAlignment="Top" 
               HorizontalAlignment="Center" RenderTransformOrigin="0.323,0.585"/>

        <!-- Button View -->
        <Button HorizontalAlignment="Center" Margin="0,25,0,0" Grid.Row="1" VerticalAlignment="Top" 
                Height="74" Width="196" Click="TrænerButton_Click">Træner</Button>

        <Button HorizontalAlignment="Center" Margin="0,188,0,0" Grid.Row="1" VerticalAlignment="Top"
                Height="74" Width="196" Click="MedlemButton_Click">Medlem</Button>





    </Grid>
</Page>
