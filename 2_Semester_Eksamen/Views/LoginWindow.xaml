<Page x:Class="_2_Semester_Eksamen.Views.LoginWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:_2_Semester_Eksamen.Views"
      mc:Ignorable="d" 
      d:DesignHeight="720"  d:DesignWidth="1280"
      Background="Wheat"
      Title="LoginWindow">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Image Margin="50" Height="200" Width="127" Source="/Icon/odense-logo.png" VerticalAlignment="Top" 
               HorizontalAlignment="Center" RenderTransformOrigin="0.323,0.585"/>

        <!-- Button View -->
        <Button HorizontalAlignment="Center" Foreground="Black" FontSize="30" FontWeight="Bold" Background="White" Margin="0,60,0,0" Grid.Row="1" VerticalAlignment="Top" 
                Height="74" Width="196" Click="TrainerButton_Click">Træner</Button>

        <Button HorizontalAlignment="Center" Foreground="Black" FontSize="30" FontWeight="Bold" Background="White" Margin="0,200,0,0" Grid.Row="1" VerticalAlignment="Top"
                Height="74" Width="196" Click="MemberButton_Click">Medlem</Button>





    </Grid>
</Page>
