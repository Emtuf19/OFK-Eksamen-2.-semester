<Window x:Class="_2_Semester_Eksamen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Odense FægteKlub" Height="720" Width="1280" WindowStartupLocation="CenterScreen">

    <Grid>
        <!-- Layout  -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>            
            <RowDefinition Height="*"/>           
        </Grid.RowDefinitions>

        <!-- NAVBAR -->
        <StackPanel
            x:Name="TrainerNavBar"
            Grid.Row="0"
            Orientation="Horizontal"
            Background="#FFA92E2E"
            VerticalAlignment="Center">

            <!-- Logo -->
            <Button Click="Home_Click">
                <Button.Template>
                    <ControlTemplate>
                        <Image
                Height="80"
                Margin="10,10"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Source="/Icon/odense-logo.png"
                Stretch="Uniform" />
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <!-- Knapper -->
            <Button x:Name="HomeBtn" Content="Home" Click="Home_Click" Style="{StaticResource NavBar}" />
            <Button x:Name="PracticeBtn" Content="Træning" Click="Practice_Click" Style="{StaticResource NavBar}"/>
            <Button x:Name="OverviewMemberBtn" Content="Medlemsoversigt" Click="OverviewMember_Click" Style="{StaticResource NavBar}"/>
            <Button x:Name="EventBtn" Content="Begivenhed" Click="Event_Click" Style="{StaticResource NavBar}"/>
            <Button x:Name="AboutBtn" Content="Om Os" Click="AboutUs_Click" Style="{StaticResource NavBar}"/>
            <Button x:Name="StaffBtn" Content="Kontakt" Click="Staff_Click" Style="{StaticResource NavBar}"/>
            <Button x:Name="LogOutBtn" Content="Log ud" Click="Logout_Click" Style="{StaticResource NavBar}"/> 
        </StackPanel>

        <!-- Frame -->
        <Frame x:Name="MainFrame"
               Grid.Row="1"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>